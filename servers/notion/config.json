{
  "schemaVersion": 1,
  "name": "notion",
  "description": "notes & databases",
  "transport": "stdio",
  "command": "npx",
  "args": [
    "-y",
    "@notionhq/notion-mcp-server"
  ],
  "env": {
    "NOTION_TOKEN": "${NOTION_API_KEY}"
  },
  "authRequired": true,
  "credentialsUrl": "https://www.notion.so/my-integrations",
  "homepage": "https://www.notion.so/"
}
