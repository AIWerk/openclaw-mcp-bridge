{
  "schemaVersion": 1,
  "name": "stripe",
  "description": "payments & billing",
  "transport": "stdio",
  "command": "npx",
  "args": [
    "-y",
    "@anthropic-pb/stripe-mcp-server",
    "--tools=all",
    "--api-key=${STRIPE_API_KEY}"
  ],
  "env": {
    "STRIPE_API_KEY": "${STRIPE_API_KEY}"
  },
  "authRequired": true,
  "credentialsUrl": "https://dashboard.stripe.com/apikeys",
  "homepage": "https://stripe.com/"
}
