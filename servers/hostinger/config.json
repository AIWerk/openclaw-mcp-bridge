{
  "schemaVersion": 1,
  "name": "hostinger",
  "description": "web hosting management",
  "transport": "stdio",
  "command": "npx",
  "args": [
    "-y",
    "@anthropic-pb/hostinger-mcp-server"
  ],
  "env": {
    "HOSTINGER_API_TOKEN": "${HOSTINGER_API_TOKEN}"
  },
  "authRequired": true,
  "credentialsUrl": "https://hpanel.hostinger.com/api",
  "homepage": "https://www.hostinger.com/"
}
